# EditorConfig for consistent code style
# See http://editorconfig.org for more

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_size = 4
indent_style = space
max_line_length = 120

# Kotlin files
[*.kt]
indent_size = 4
ij_kotlin_packages_to_use_star_imports = 
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_allow_trailing_comma = true
ij_kotlin_class_count_to_use_star_import = 2147483647

# Java files
[*.java]
indent_size = 4

# XML files
[*.xml]
indent_size = 2

# Gradle files
[*.gradle.kts]
indent_size = 4

# Properties files
[*.properties]
indent_size = 2

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.yaml,*.yml]
indent_size = 2
